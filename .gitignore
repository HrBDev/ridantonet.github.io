# ============================================================
# .gitignore — Khashayar YouTube Downloader
# ============================================================

# ── Operating System Files ─────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE & Editor Files ─────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.code-workspace

# ── Node.js (if applicable in future) ──────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ── Build & Cache ──────────────────────────────
*.log
*.tmp
*.temp
.cache/
dist/
build/

# ── Environment & Secrets ──────────────────────
.env
.env.local
.env.production
.env.development
*.secret
credentials.json

# ── Temporary Download Files ───────────────────
*.part
*.ytdl
*.crdownload
*.partial

# ── Python Cache ───────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt
.venv/
venv/
env/

# ── Docker ─────────────────────────────────────
.dockerignore
docker-compose.override.yml

# ── Miscellaneous ──────────────────────────────
*.bak
*.orig
*.old
*.swp
